// School Management System — Prisma Schema
// DB: PostgreSQL (local, on-premises)
// GDPR: AuditLog covers all sensitive data access

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  HEADMASTER
  HEADTEACHER_A
  HEADTEACHER_B
  STUDENT_COUNSELOR
  TEACHER
  SCHOOL_ADMIN
  CHAPERONE
  STUDENT
  PARENT
}

enum Gender {
  MALE
  FEMALE
}

enum ParentRole {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ReferralRecommendation {
  NO_RECOMMENDATION
  EXPULSION
  STRICT_MEASURE
  OBSERVATION
  STRICT_OBSERVATION
  NOTIFY_PARENTS
  OTHER_RECOMMENDATION
}

enum ResolutionAction {
  DETENTION
  PEDAGOGICAL_DIALOGUE
  WRITTEN_AGREEMENT
  WARNING
  OTHER
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubstitutionRequestType {
  ABSENCE
  EXEMPTION
  ROOM_CHANGE
}

enum SubstitutionPlanStatus {
  DRAFT
  FINAL
}

enum SubstitutionKind {
  COVER // a substitute teacher covers the vacant lesson
  STUDY_HALL // Φ/δι with the on-duty deputy (no substitute found / 2nd of double period)
  RELEASE // class released (vacant lesson at the day's last period)
  SWAP // another teacher's last-period lesson with the same class moved up
  ROOM_CHANGE // requested or cascaded room move
  SUPPORT_MERGE // support (ΣΤ…) students join their regular class
}

enum TestType {
  SMALL
  BIG
}

enum SpecialDayType {
  INTERCALARY
  EXCURSION
  BANK_HOLIDAY
  CHRISTMAS
  EASTER
  OTHER_HOLIDAY
  SCHOOL_EVENT
}

// ─── NextAuth ─────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  // `name` stays the composed full name ("first last") used for display/search
  // across the app; firstName/lastName hold the split parts edited in the profile.
  name         String?
  firstName    String?
  lastName     String?
  nameEl       String?
  passwordHash String?  // Parents only — staff use Entra ID
  image        String?
  role         Role
  // Secondary roles granted on top of the primary one. Currently only
  // SUPER_ADMIN is ever assigned here (a teacher who also administers the
  // system keeps their teacher role and features). Authorization: the primary
  // role drives everything; an extra SUPER_ADMIN additionally unlocks the
  // admin portal + admin procedures (see authz.ts / trpc/init.ts).
  extraRoles   Role[]   @default([])
  entraId      String?  @unique
  isActive     Boolean  @default(true)
  // Per-account appearance preferences
  colorTheme   String   @default("emerald") // emerald | ocean | violet | rose | amber
  fontSize     String   @default("small")   // small | medium | large

  accounts Account[]
  sessions Session[]

  staffProfile   StaffProfile?
  studentProfile StudentProfile?
  parentProfile  ParentProfile?

  uploadedNotices               Notice[]
  resolvedReferrals             ReferralResolution[]
  resolvedReferralStudents      ReferralStudentResolution[] @relation("ReferralStudentResolver")
  resolutionUnlockRequests      ResolutionUnlockRequest[]   @relation("ResolutionUnlockRequester")
  resolutionUnlockDecisions     ResolutionUnlockRequest[]   @relation("ResolutionUnlockDecider")
  substitutionPlansGenerated    SubstitutionPlan[]          @relation("SubstitutionPlanGenerator")
  substitutionPlansFinalized    SubstitutionPlan[]          @relation("SubstitutionPlanFinalizer")
  notifications                 Notification[]
  sentNotifications             Notification[] @relation("SentNotifications")
  attendanceExports             AttendanceExport[]
  waivedAttendance              Attendance[] @relation("AttendanceWaiver")
  auditLogs            AuditLog[]
  chaperoneAssignments ActivityChaperone[]
  teacherClaim         TeacherClaim?
  chaperoneRequests    ChaperoneRequest[]
  startedConversations Conversation[] @relation("ConversationStarter")
  authoredMessages     Message[]      @relation("MessageAuthor")
  announcements        Announcement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffProfile {
  id         String  @id @default(cuid())
  userId     String? @unique
  user       User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  phone      String?
  department String?
  pmp        String? // ΠΜΠ — personnel/payroll number, asked at first sign-in
  // Canonical display name in the timetable's coding (e.g. "ΗΥ-ΜΑΣΙΑ Μ. ΒΔ").
  // Copied from the schedule's staffName when the profile is linked to slots.
  scheduleName String?
  // Designation: deputy B responsible for special education (set by admin)
  specialEducation Boolean @default(false)
  // Designation: the teacher who runs the daily substitution plan (set by admin)
  substitutionCoordinator Boolean @default(false)
  // Designation: the headteacher responsible for ΔΔΚ (set by admin)
  ddkCoordinator Boolean @default(false)
  // Substitution quota: null = unlimited, 0 = never picked
  maxSubstitutions Int?

  homeroomGroups        Group[]            @relation("HomeroomTeacher")
  homeroomHeadGroups    Group[]            @relation("HomeroomHeadteacher")
  homeroomCounselorGroups Group[]          @relation("HomeroomCounselor")
  courseAssignments CourseAssignment[]
  filedReferrals    Referral[]         @relation("ReferralFiler")
  attendanceRecords Attendance[]       @relation("AttendanceTeacher")
  issuedPermits     ExitPermit[]       @relation("PermitIssuer")
  filedActivities   Activity[]         @relation("ActivityFiler")
  timetableSlots    TimetableSlot[]
  testSchedules     TestSchedule[]
  grades            Grade[]
  dutyDays          DutyRosterEntry[]
  substitutionRequests     SubstitutionRequest[]   @relation("SubstitutionRequester")
  substitutionAbsences     SubstitutionPlanEntry[] @relation("SubstitutionAbsent")
  substitutionAssignments  SubstitutionPlanEntry[] @relation("SubstitutionSubstitute")
  toiletBreaks             ToiletBreak[]
  ddkAwards                DdkAward[]              @relation("DdkAwarder")
  conversations            Conversation[]
}

model StudentProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId      String    @unique
  groupId        String?
  group          Group?    @relation(fields: [groupId], references: [id])
  gender         Gender?
  dateOfBirth    DateTime? @db.Date
  placeOfBirth   String?
  nationality    String?
  idCardNumber   String?
  passportNumber String?

  parents                ParentStudent[]
  subjectGroups          StudentGroup[]
  smsContacts            SmsContact[]
  smsLogs                SmsLog[]
  attendance             Attendance[]
  grades                 Grade[]
  testGrades             TestGrade[]
  referrals              Referral[]           @relation("StudentReferrals")
  referralStudents       ReferralStudent[]    @relation("ReferralStudentProfile")
  exitPermits            ExitPermit[]
  activityParticipations   ActivityParticipant[]
  chaperoneRequestStudents ChaperoneRequestStudent[]
  accessCode               StudentAccessCode?
  toiletBreaks             ToiletBreak[]
  ddkAwards                DdkAward[]
  conversations            Conversation[]
  specialEd                SpecialEdRecord?
  // Flagged when the import's default SMS number is missing or doesn't match a
  // parent/guardian — the office should review the recipient.
  smsFlagged               Boolean   @default(false)
  smsFlagReason            String?
}

model ParentProfile {
  id     String     @id @default(cuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone  String?
  role   ParentRole

  children    ParentStudent[]
  smsContacts SmsContact[]
}

model ParentStudent {
  id               String         @id @default(cuid())
  parentProfileId  String
  parentProfile    ParentProfile  @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([parentProfileId, studentProfileId])
}

// ─── Special Education ────────────────────────────────────────────────────────
// Sensitive. The record's presence marks a student as special-ed. Disability
// (problem) codes and accommodations are extensible lookups (seeded from the
// ministry ΚΩΔΙΚΟΙ list). Support (ΣΤΗΡ) is NOT stored — it is derived from the
// student's ΣΤ_/ΑΣΤ_ support-group enrolment in the timetable.

model SpecialEdProblemCode {
  id     String  @id @default(cuid())
  code   String  @unique // e.g. "ΔΞ"
  label  String          // e.g. "Δυσλεξία"
  active Boolean @default(true)

  records SpecialEdRecord[] @relation("RecordProblems")
}

model SpecialEdAccommodation {
  id     String  @id @default(cuid())
  code   String  @unique // "1".."18"
  label  String
  active Boolean @default(true)

  records SpecialEdRecord[] @relation("RecordAccommodations")
}

model SpecialEdRecord {
  id              String         @id @default(cuid())
  studentId       String         @unique
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fileNo          String? // ΑΡ. ΦΑΚ.
  remarks         String? // ΠΑΡΑΤΗΡΗΣΕΙΣ — full-access viewers only
  frenchExempt    Boolean        @default(false) // Απαλλαγή Γαλλικών
  otherExemptions String? // Άλλες Απαλλαγές — full-access viewers only

  problems       SpecialEdProblemCode[]   @relation("RecordProblems")
  accommodations SpecialEdAccommodation[] @relation("RecordAccommodations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Subject Group Enrollments ────────────────────────────────────────────────
// Many-to-many: students ↔ schedule groups (from the group-enrollment file).
// Separate from StudentProfile.groupId which holds the homeroom class.

model StudentGroup {
  id               String         @id @default(cuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  groupId          String
  group            Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, groupId])
  @@index([groupId])
}

// ─── SMS Contacts ─────────────────────────────────────────────────────────────

model SmsContact {
  id              String         @id @default(cuid())
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name            String
  phone           String
  role            ParentRole
  active          Boolean        @default(true)
  // The default recipient for this student (from the import's "τηλέφωνο SMS").
  isDefault       Boolean        @default(false)
  parentProfileId String?
  parentProfile   ParentProfile? @relation(fields: [parentProfileId], references: [id], onDelete: SetNull)

  smsLogs     SmsLog[]
  exitPermits ExitPermit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([studentId, active])
}

// ─── Groups ───────────────────────────────────────────────────────────────────

model Group {
  id                String        @id @default(cuid())
  name              String        @unique
  grade             Int           // 1, 2, or 3
  homeroomTeacherId     String?
  homeroomTeacher       StaffProfile? @relation("HomeroomTeacher", fields: [homeroomTeacherId], references: [id])
  homeroomHeadteacherId String?
  homeroomHeadteacher   StaffProfile? @relation("HomeroomHeadteacher", fields: [homeroomHeadteacherId], references: [id])
  counselorId           String?
  counselor             StaffProfile? @relation("HomeroomCounselor", fields: [counselorId], references: [id])

  students          StudentProfile[]
  studentGroups     StudentGroup[]
  courseAssignments CourseAssignment[]
  timetableSlots    TimetableSlot[]
  referrals         Referral[]       @relation("ReferralGroup")
  referralStudents  ReferralStudent[] @relation("ReferralStudentGroup")
  testSchedules     TestSchedule[]
  substitutionRequests    SubstitutionRequest[]   @relation("SubstitutionRequestGroup")
  substitutionPlanEntries SubstitutionPlanEntry[] @relation("SubstitutionEntryGroup")
  toiletBreaks            ToiletBreak[]
  attendanceExports       AttendanceExport[]
}

// ─── Curriculum ───────────────────────────────────────────────────────────────

model Course {
  id     String @id @default(cuid())
  name   String
  nameEl String
  code   String @unique

  assignments    CourseAssignment[]
  grades         Grade[]
  timetableSlots TimetableSlot[]
  testSchedules  TestSchedule[]
}

model CourseAssignment {
  id       String       @id @default(cuid())
  courseId String
  course   Course       @relation(fields: [courseId], references: [id])
  staffId  String
  staff    StaffProfile @relation(fields: [staffId], references: [id])
  groupId  String?
  group    Group?       @relation(fields: [groupId], references: [id])

  @@unique([courseId, staffId, groupId])
}

// ─── Timetable ────────────────────────────────────────────────────────────────

model TimetableSlot {
  id        String        @id @default(cuid())
  groupId   String
  group     Group         @relation(fields: [groupId], references: [id])
  courseId  String
  course    Course        @relation(fields: [courseId], references: [id])
  staffId   String?       // null until teacher claims the slot
  staff     StaffProfile? @relation(fields: [staffId], references: [id])
  staffName String?       // raw name from import for matching
  dayOfWeek Int           // 1=Mon … 5=Fri
  period    Int           // 1-based
  room      String?

  attendance Attendance[]
  substitutionPlanEntries SubstitutionPlanEntry[]

  @@unique([groupId, dayOfWeek, period])
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model Attendance {
  id              String           @id @default(cuid())
  studentId       String
  student         StudentProfile   @relation(fields: [studentId], references: [id])
  timetableSlotId String?
  timetableSlot   TimetableSlot?   @relation(fields: [timetableSlotId], references: [id])
  staffId         String
  staff           StaffProfile     @relation("AttendanceTeacher", fields: [staffId], references: [id])
  date            DateTime         @db.Date
  status          AttendanceStatus
  minutesDelayed  Int              @default(0)
  isAutoAbsent    Boolean          @default(false)
  smsSent         Boolean          @default(false)
  // Absence covered by an exit permit (Άδεια Εξόδου) — informs the office admin
  exitPermitId    String?
  exitPermit      ExitPermit?      @relation(fields: [exitPermitId], references: [id], onDelete: SetNull)
  // Intercalary period attendance (when timetableSlotId is null)
  intercalaryGroupId String?
  intercalaryPeriod  Int?
  // Soft-erased (διαγραφή απουσίας): stays on record but does not count
  // towards any totals.
  waived     Boolean   @default(false)
  waivedAt   DateTime?
  waivedById String?
  waivedBy   User?     @relation("AttendanceWaiver", fields: [waivedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, timetableSlotId, date])
  @@unique([studentId, intercalaryGroupId, intercalaryPeriod, date])
  @@index([date])
  @@index([studentId, date])
}

// ─── Substitutions (Αναπληρώσεις) ─────────────────────────────────────────────

// A teacher's filed request: absence (day/range/periods), exemption from
// substitution duty for a date, or a room change.
model SubstitutionRequest {
  id            String                  @id @default(cuid())
  staffId       String
  staff         StaffProfile            @relation("SubstitutionRequester", fields: [staffId], references: [id], onDelete: Cascade)
  type          SubstitutionRequestType
  startDate     DateTime                @db.Date
  endDate       DateTime?               @db.Date // ABSENCE multi-day range; null = single day
  periods       Int[]                   @default([]) // ABSENCE specific periods / ROOM_CHANGE period; empty = whole day(s)
  reason        String? // Ασθένεια, Στρατός, … (ABSENCE) — free text via reasonDetails
  reasonDetails String? // "Άλλο" specification / extra info
  // ROOM_CHANGE only
  groupId       String?
  group         Group?                  @relation("SubstitutionRequestGroup", fields: [groupId], references: [id])
  newRoom       String?
  smsSent       Boolean                 @default(false)
  createdAt     DateTime                @default(now())

  planEntries SubstitutionPlanEntry[]

  @@index([startDate])
  @@index([staffId])
}

// One generated daily plan per date. DRAFT until the coordinator finalizes;
// only FINAL plans affect schedules and notify substitutes.
model SubstitutionPlan {
  id            String                 @id @default(cuid())
  date          DateTime               @unique @db.Date
  status        SubstitutionPlanStatus @default(DRAFT)
  generatedById String
  generatedBy   User                   @relation("SubstitutionPlanGenerator", fields: [generatedById], references: [id])
  finalizedById String?
  finalizedBy   User?                  @relation("SubstitutionPlanFinalizer", fields: [finalizedById], references: [id])
  finalizedAt   DateTime?
  createdAt     DateTime               @default(now())

  entries SubstitutionPlanEntry[]
}

model SubstitutionPlanEntry {
  id     String           @id @default(cuid())
  planId String
  plan   SubstitutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  kind   SubstitutionKind
  period Int?

  groupId String?
  group   Group?  @relation("SubstitutionEntryGroup", fields: [groupId], references: [id])

  absentStaffId String?
  absentStaff   StaffProfile? @relation("SubstitutionAbsent", fields: [absentStaffId], references: [id])

  substituteStaffId String?
  substituteStaff   StaffProfile? @relation("SubstitutionSubstitute", fields: [substituteStaffId], references: [id])

  // The covered timetable slot — drives schedule injection + attendance authorization
  timetableSlotId String?
  timetableSlot   TimetableSlot? @relation(fields: [timetableSlotId], references: [id], onDelete: SetNull)

  room     String?
  newRoom  String?
  note     String? // human-readable: "Αλλαγή από 7η σε 3η", reason, etc.
  rankInfo String? // selection trace shown to the coordinator

  sourceRequestId String?
  sourceRequest   SubstitutionRequest? @relation(fields: [sourceRequestId], references: [id], onDelete: SetNull)

  @@index([planId, kind])
  @@index([substituteStaffId])
  @@index([absentStaffId])
}

// ─── Exit Permits ─────────────────────────────────────────────────────────────

// Issued by the day's on-duty deputy (Εφημερεύων Βοηθός) after the parents
// agree by phone. Covers fromPeriod → end of the school day.
model ExitPermit {
  id          String         @id @default(cuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  issuerId    String
  issuer      StaffProfile   @relation("PermitIssuer", fields: [issuerId], references: [id])
  date        DateTime       @db.Date // school day it covers
  fromPeriod  Int // student leaves from this period to end of day
  reason      String
  // The parent/guardian the deputy spoke with (picked from the student's contacts);
  // contactNote is the free-text fallback when no contacts are on record.
  smsContactId String?
  smsContact   SmsContact?   @relation(fields: [smsContactId], references: [id], onDelete: SetNull)
  contactNote String?
  issuedAt    DateTime       @default(now())
  active      Boolean        @default(true) // false = cancelled
  attendance  Attendance[]

  @@index([date, studentId])
}

// ─── Activities ───────────────────────────────────────────────────────────────

model Activity {
  id          String       @id @default(cuid())
  name        String
  filerId     String
  filer       StaffProfile @relation("ActivityFiler", fields: [filerId], references: [id])
  date        DateTime     @db.Date
  startPeriod Int
  endPeriod   Int
  location    String?

  participants ActivityParticipant[]
  chaperones   ActivityChaperone[]
  ddkAwards    DdkAward[]
}

model ActivityParticipant {
  id         String         @id @default(cuid())
  activityId String
  activity   Activity       @relation(fields: [activityId], references: [id])
  studentId  String
  student    StudentProfile @relation(fields: [studentId], references: [id])

  @@unique([activityId, studentId])
}

model ActivityChaperone {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId])
}

// ─── ΔΔΚ (Δημιουργικότητα – Δράση – Κοινωνική Προσφορά) ────────────────────────
// Points a student earns for extracurricular contribution, per the Ministry's
// evaluation guide. Usually created by converting a filed Activity; the points
// reset each school year. Categories live in src/lib/ddk.ts (the printed guide).
model DdkAward {
  id           String         @id @default(cuid())
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  categoryCode String         // catalog code, e.g. "A4a", "Z2f" (see src/lib/ddk.ts)
  points       Int
  note         String?        // optional detail (role, distinction level, …)
  activityId   String?        // source activity when converted from one
  activity     Activity?      @relation(fields: [activityId], references: [id], onDelete: SetNull)
  awardedById  String
  awardedBy    StaffProfile   @relation("DdkAwarder", fields: [awardedById], references: [id])
  schoolYear   String         // "2025-2026" — points are tallied per school year
  createdAt    DateTime       @default(now())

  @@index([studentId, schoolYear])
  @@index([activityId])
}

// ─── Claims & Requests ────────────────────────────────────────────────────────

// A teacher selects which staffName in the timetable belongs to them.
// Admin approves → StaffProfile created and TimetableSlots linked.
model TeacherClaim {
  id        String      @id @default(cuid())
  userId    String      @unique
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  staffName String
  status    ClaimStatus @default(PENDING)
  createdAt DateTime    @default(now())
}

// A chaperone requests responsibility for a set of students.
// Admin approves → chaperone can view those students in their portal.
model ChaperoneRequest {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      String?     @db.Text
  status    ClaimStatus @default(PENDING)
  students  ChaperoneRequestStudent[]
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([status])
}

model ChaperoneRequestStudent {
  id               String           @id @default(cuid())
  requestId        String
  request          ChaperoneRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([requestId, studentProfileId])
  @@index([studentProfileId])
}

// ─── Grades ───────────────────────────────────────────────────────────────────

model Grade {
  id        String         @id @default(cuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])
  courseId  String
  course    Course         @relation(fields: [courseId], references: [id])
  staffId   String
  staff     StaffProfile   @relation(fields: [staffId], references: [id])
  value     Decimal        @db.Decimal(4, 2)
  period    String
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseId, period])
}

// ─── Tests ────────────────────────────────────────────────────────────────────

model TestSchedule {
  id       String       @id @default(cuid())
  courseId String
  course   Course       @relation(fields: [courseId], references: [id])
  groupId  String
  group    Group        @relation(fields: [groupId], references: [id])
  staffId  String
  staff    StaffProfile @relation(fields: [staffId], references: [id])
  date        DateTime     @db.Date
  period      Int
  periodCount Int          @default(1)  // 1 or 2 periods (BIG tests only)
  type        TestType     @default(BIG)

  createdAt  DateTime    @default(now())
  testGrades TestGrade[]

  @@index([groupId, date])
}

model TestGrade {
  id             String         @id @default(cuid())
  testScheduleId String
  testSchedule   TestSchedule   @relation(fields: [testScheduleId], references: [id], onDelete: Cascade)
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [id])
  value          Decimal?       @db.Decimal(4, 2)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([testScheduleId, studentId])
  @@index([studentId])
}

// ─── Referrals ────────────────────────────────────────────────────────────────

model Referral {
  id             String         @id @default(cuid())
  // Human-friendly sequential identifier for easy coordination (e.g. "#42").
  number         Int            @unique @default(autoincrement())
  // Legacy single-student fields (nullable; kept for old data only)
  studentId      String?
  student        StudentProfile? @relation("StudentReferrals", fields: [studentId], references: [id])
  groupId        String?
  group          Group?          @relation("ReferralGroup", fields: [groupId], references: [id])
  resolution     ReferralResolution?

  filerId        String
  filer          StaffProfile   @relation("ReferralFiler", fields: [filerId], references: [id])
  description    String         @db.Text
  location       String?
  incidentTime   String?
  extraInfo      String?        @db.Text
  recommendation ReferralRecommendation @default(NO_RECOMMENDATION)
  date           DateTime
  isDraft        Boolean        @default(false)
  // Set the first time a headteacher opens the referral to examine it.
  // Drives the at-a-glance colour: unopened+unresolved = red, opened/partial = yellow, all resolved = green.
  openedAt       DateTime?
  counselorNotes String?        @db.Text

  students  ReferralStudent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDraft])
}

enum ReferralStudentStatus {
  PENDING
  RESOLVED
}

model ReferralStudent {
  id         String              @id @default(cuid())
  referralId String
  referral   Referral            @relation(fields: [referralId], references: [id], onDelete: Cascade)
  studentId  String
  student    StudentProfile      @relation("ReferralStudentProfile", fields: [studentId], references: [id])
  groupId    String?
  group      Group?              @relation("ReferralStudentGroup", fields: [groupId], references: [id])
  status     ReferralStudentStatus @default(PENDING)

  resolution     ReferralStudentResolution?
  unlockRequests ResolutionUnlockRequest[]

  @@unique([referralId, studentId])
  @@index([studentId])
  @@index([groupId])
}

model ReferralStudentResolution {
  id                String          @id @default(cuid())
  referralStudentId String          @unique
  referralStudent   ReferralStudent @relation(fields: [referralStudentId], references: [id], onDelete: Cascade)
  action            ResolutionAction
  // Required description of the punishment (what exactly was imposed/agreed).
  // Nullable only for legacy rows created before the field existed.
  actionDetails     String?         @db.Text
  notes             String?         @db.Text
  counselorNotes    String?         @db.Text
  parentContacted   Boolean         @default(false)
  parentContactDate   DateTime?
  parentContactMethod String?
  resolvedById      String
  resolvedBy        User            @relation("ReferralStudentResolver", fields: [resolvedById], references: [id])
  resolvedAt        DateTime        @default(now())

  expulsionDays     ReferralExpulsionDay[]
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// A headteacher's request to UNLOCK a resolution they made. Admin approval
// deletes the resolution and moves the student back to PENDING — the referral
// returns to the examine tab so it can be resolved afresh.
model ResolutionUnlockRequest {
  id                String          @id @default(cuid())
  referralStudentId String
  referralStudent   ReferralStudent @relation(fields: [referralStudentId], references: [id], onDelete: Cascade)
  requestedById     String
  requestedBy       User            @relation("ResolutionUnlockRequester", fields: [requestedById], references: [id])
  reason            String          @db.Text // why the unlock is needed
  // Snapshot of the resolution at request time (JSON) — kept for the trail,
  // since approval deletes the resolution itself.
  snapshot          String?         @db.Text
  status            EditRequestStatus @default(PENDING)
  decidedById       String?
  decidedBy         User?           @relation("ResolutionUnlockDecider", fields: [decidedById], references: [id])
  decidedAt         DateTime?
  createdAt         DateTime        @default(now())

  @@index([status])
  @@index([referralStudentId])
}

model ReferralExpulsionDay {
  id           String                    @id @default(cuid())
  resolutionId String
  resolution   ReferralStudentResolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  date         DateTime                  @db.Date

  @@unique([resolutionId, date])
  @@index([resolutionId])
}

model ReferralResolution {
  id         String           @id @default(cuid())
  referralId String           @unique
  referral   Referral         @relation(fields: [referralId], references: [id])
  action     ResolutionAction
  notes      String?          @db.Text

  parentContacted     Boolean   @default(false)
  parentContactDate   DateTime?
  parentContactMethod String?

  resolvedById String
  resolvedBy   User     @relation(fields: [resolvedById], references: [id])
  resolvedAt   DateTime @default(now())
}

// ─── Attendance export log — which day's report the office downloaded ────────

model AttendanceExport {
  id           String   @id @default(cuid())
  date         DateTime @db.Date // the report day that was downloaded
  groupId      String? // null = whole school
  group        Group?   @relation(fields: [groupId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  records      Int // how many rows the CSV contained
  downloadedAt DateTime @default(now())

  @@index([date])
}

// ─── Toilet breaks (έξοδοι τουαλέτας κατά τη διάρκεια μαθήματος) ─────────────

model ToiletBreak {
  id         String         @id @default(cuid())
  studentId  String
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staffId    String // who recorded the exit
  staff      StaffProfile   @relation(fields: [staffId], references: [id])
  groupId    String?
  group      Group?         @relation(fields: [groupId], references: [id])
  date       DateTime       @db.Date
  period     Int
  leftAt     DateTime
  returnedAt DateTime? // null = still out

  @@index([date, returnedAt])
  @@index([studentId, date])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  linkUrl   String?
  read      Boolean   @default(false)
  noticedAt DateTime?
  createdAt DateTime  @default(now())
  // Who composed it (staff messages) — enables the sender's read-receipt view
  senderId  String?
  sender    User?     @relation("SentNotifications", fields: [senderId], references: [id])

  @@index([userId, read])
  @@index([userId, noticedAt])
  @@index([senderId])
}

// ─── Messaging (parents/students ↔ staff) ─────────────────────────────────────
// Two-way threads started by a parent or student to one staff member, about a
// specific student. Staff reply only. Homegroup staff/admin get an oversight view.
model Conversation {
  id        String         @id @default(cuid())
  studentId String         // the student the thread concerns (for oversight scope)
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staffId   String         // the staff participant (recipient)
  staff     StaffProfile   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  starterId String         // the parent/student user who opened the thread
  starter   User           @relation("ConversationStarter", fields: [starterId], references: [id], onDelete: Cascade)
  subject   String?

  staffReadAt  DateTime? // last time the staff participant read it
  familyReadAt DateTime? // last time the starter (parent/student) read it

  createdAt     DateTime @default(now())
  lastMessageAt DateTime @default(now())

  messages Message[]

  @@index([staffId, lastMessageAt])
  @@index([starterId, lastMessageAt])
  @@index([studentId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body           String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ─── Noticeboard ──────────────────────────────────────────────────────────────

model Notice {
  id           String      @id @default(cuid())
  title        String
  titleEl      String?
  body         String      @db.Text
  bodyEl       String?     @db.Text
  uploadedById String
  uploadedBy   User        @relation(fields: [uploadedById], references: [id])
  fileId       String?
  file         StoredFile? @relation(fields: [fileId], references: [id])
  urgent       Boolean     @default(false)
  staffOnly    Boolean     @default(false)
  gradeTarget  Int?

  tags            NoticeTag[]
  acknowledgments NoticeAcknowledgment[]

  createdAt DateTime @default(now())
}

model NoticeTag {
  id       String @id @default(cuid())
  noticeId String
  notice   Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  tag      String
}

model NoticeAcknowledgment {
  id       String   @id @default(cuid())
  noticeId String
  notice   Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  userId   String
  readAt   DateTime @default(now())

  @@unique([noticeId, userId])
}

// ─── Daily Announcements ──────────────────────────────────────────────────────
// Short notices pushed by management (headteachers/headmaster) and surfaced on
// the teacher dashboard. An announcement shows while pinnedUntil >= today, so a
// post defaults to "today only" but can be kept up for several days.
model Announcement {
  id          String   @id @default(cuid())
  title       String?
  body        String   @db.Text
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  pinnedUntil DateTime @db.Date
  createdAt   DateTime @default(now())

  @@index([pinnedUntil])
}

// ─── File Storage ─────────────────────────────────────────────────────────────

model StoredFile {
  id           String   @id @default(cuid())
  filename     String
  path         String
  mimeType     String
  size         Int
  uploadedById String
  category     String?

  notices Notice[]

  createdAt DateTime @default(now())
}

// ─── SMS Log ──────────────────────────────────────────────────────────────────

model SmsLog {
  id              String         @id @default(cuid())
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id])
  smsContactId    String?
  smsContact      SmsContact?    @relation(fields: [smsContactId], references: [id], onDelete: SetNull)
  phoneNumber     String
  message         String
  status          String
  gatewayResponse String?

  sentAt DateTime @default(now())
}

// ─── External: Exam Auditing ─────────────────────────────────────────────────
// These tables belong to a separate exam-auditing project sharing this DB.

model Template {
  id            Int      @id @default(autoincrement())
  totalPoints   Float    @map("total_points")
  maxPointsJson String   @map("max_points_json")
  createdAt     DateTime @default(now()) @db.Timestamptz @map("created_at")

  auditResults   AuditResult[]
  ldAuditResults LdAuditResult[]

  @@map("templates")
}

model AuditResult {
  id                 Int      @id @default(autoincrement())
  templateId         Int      @map("template_id")
  template           Template @relation(fields: [templateId], references: [id])
  markerId           String?  @map("marker_id")
  signaturePresent   Boolean  @map("signature_present")
  awardedPointsJson  String   @map("awarded_points_json")
  calculatedSum      Float    @map("calculated_sum")
  writtenTotal       Float?   @map("written_total")
  writtenGrade20     Float?   @map("written_grade20")
  gradeConversion    Float    @map("grade_conversion")
  markerIdMissing    Boolean  @map("marker_id_missing")
  writtenTotalAbsent Boolean  @map("written_total_absent")
  additionError      Boolean  @map("addition_error")
  exceededPoints     Boolean  @map("exceeded_points")
  conversionAbsent   Boolean  @map("conversion_absent")
  conversionError    Boolean  @map("conversion_error")
  passed             Boolean
  createdAt          DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@map("audit_results")
}

model LdAuditResult {
  id                  Int      @id @default(autoincrement())
  templateId          Int      @map("template_id")
  template            Template @relation(fields: [templateId], references: [id])
  markerId            String?  @map("marker_id")
  signaturePresent    Boolean  @map("signature_present")
  awardedPointsJson   String   @map("awarded_points_json")
  ldCalculatedSum     Float    @map("ld_calculated_sum")
  ldGrade20           Float    @map("ld_grade20")
  writtenGrade20      Float?   @map("written_grade20")
  q6SignaturePresent  Boolean  @map("q6_signature_present")
  q7SignaturePresent  Boolean  @map("q7_signature_present")
  q11SignaturePresent Boolean  @map("q11_signature_present")
  q11CrossedOut       Boolean  @map("q11_crossed_out")
  markerIdMissing     Boolean  @map("marker_id_missing")
  conversionAbsent    Boolean  @map("conversion_absent")
  conversionError     Boolean  @map("conversion_error")
  passed              Boolean
  createdAt           DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@map("ld_audit_results")
}

// ─── Global Settings ──────────────────────────────────────────────────────────

model GlobalSetting {
  key   String @id
  value String
}

// ─── Self-service access (students & parents) ─────────────────────────────────

// One redeemable access code per student. The student redeems it once to set up
// their account; any number of guardians can redeem the same code to create
// their own (separate, email-verified) parent accounts. Stays valid until an
// authorised staff member regenerates it.
model StudentAccessCode {
  id               String         @id @default(cuid())
  studentProfileId String         @unique
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  code             String         @unique
  studentClaimedAt DateTime?
  guardianClaims   Int            @default(0)
  createdById      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// Short-lived staging row for the email-verification (OTP) step of redemption.
// Holds the already-hashed password and the pending account details until the
// emailed code is confirmed, then it is consumed.
model EmailOtp {
  id               String   @id @default(cuid())
  email            String
  codeHash         String
  purpose          String   // "ACTIVATE_STUDENT" | "ACTIVATE_GUARDIAN"
  studentProfileId String
  name             String?
  passwordHash     String
  expiresAt        DateTime
  attempts         Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ─── School Calendar ──────────────────────────────────────────────────────────
// Term dates and test deadlines live in the "termDates" GlobalSetting
// (Settings → School Year & Terms), not in a table.

// Fixed weekly on-duty schedule (Εφημερεύοντες Βοηθοί): which deputy heads
// are on duty on each school day. Resolved per-date via getOnDutyDeputies().
model DutyRosterEntry {
  id             String       @id @default(cuid())
  dayOfWeek      Int          // 1 (Mon) – 5 (Fri)
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@unique([dayOfWeek, staffProfileId])
  @@index([dayOfWeek])
}

model SpecialDay {
  id                       String         @id @default(cuid())
  type                     SpecialDayType
  startDate                DateTime       @db.Date
  endDate                  DateTime       @db.Date
  label                    String?
  intercalaryMeetingPeriod Int?           // only for INTERCALARY type
  eventStartPeriod         Int?           // only for SCHOOL_EVENT type
  eventEndPeriod           Int?           // only for SCHOOL_EVENT type
  createdAt                DateTime       @default(now())
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
}
